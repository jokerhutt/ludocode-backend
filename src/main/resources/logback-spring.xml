<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <springProfile name="prod | admin">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${LOKI_URL}</url>
            </http>

            <format>
                <label>
                    <pattern>app=ludocode-backend,level=%level</pattern>
                </label>

                <message>
                    <pattern>%msg</pattern>
                </message>
            </format>
        </appender>

        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

    <springProfile name="!prod &amp; !admin">
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>

</configuration>