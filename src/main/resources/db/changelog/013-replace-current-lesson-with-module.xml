<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="013-01-replace-current-lesson-with-module" author="dave" dbms="postgresql">

        <dropColumn
                tableName="course_progress"
                columnName="current_lesson_id"/>

        <addColumn tableName="course_progress">
            <column name="current_module_id" type="uuid"/>
        </addColumn>

    </changeSet>

</databaseChangeLog>