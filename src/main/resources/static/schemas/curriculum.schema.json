{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ludocode.dev/schemas/curriculum.schema.json",
  "description": "Schema for Ludocode curriculum YAML",

  "type": "object",
  "required": ["title", "courseType", "modules"],

  "properties": {
    "title": { "type": "string" },

    "description": {
      "type": ["string", "null"]
    },

    "courseType": {
      "type": "string",
      "enum": ["COURSE", "SKILL_PATH"]
    },

    "languageId": {
      "type": ["integer", "null"]
    },

    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" }
    }
  },

  "$defs": {

    "module": {
      "type": "object",
      "required": ["title", "lessons"],
      "properties": {

        "id": {
          "type": "string",
          "format": "uuid"
        },

        "title": {
          "type": "string"
        },

        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lesson" }
        }
      }
    },

    "lesson": {
      "type": "object",
      "required": ["title", "exercises", "lessonType"],
      "properties": {

        "id": {
          "type": "string",
          "format": "uuid"
        },

        "lessonType": {
          "type": "string",
          "enum": ["NORMAL", "GUIDED"]
        },

        "title": {
          "type": "string"
        },

        "exercises": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/exercise" }
        }
      },

      "allOf": [
        {
          "if": {
            "properties": { "lessonType": { "const": "GUIDED" } }
          },
          "then": {
            "properties": {
              "exercises": {
                "items": {
                  "required": ["interaction"],
                  "properties": {
                    "interaction": {
                      "properties": {
                        "type": { "const": "EXECUTABLE" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "lessonType": { "const": "NORMAL" } }
          },
          "then": {
            "properties": {
              "exercises": {
                "items": {
                  "properties": {
                    "interaction": {
                      "not": {
                        "properties": {
                          "type": { "const": "EXECUTABLE" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "exercise": {
      "type": "object",
      "required": ["blocks"],
      "properties": {

        "exerciseId": {
          "type": "string",
          "format": "uuid"
        },

        "exerciseVersion": {
          "type": "integer"
        },

        "blocks": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/headerBlock" },
              { "$ref": "#/$defs/paragraphBlock" },
              { "$ref": "#/$defs/codeBlock" },
              { "$ref": "#/$defs/mediaBlock" },
              { "$ref": "#/$defs/instructionsBlock" }
            ]
          }
        },

        "interaction": {
          "type": ["object", "null"],
          "required": ["type"],
          "allOf": [
            {
              "if": {
                "properties": {
                  "type": { "const": "SELECT" }
                }
              },
              "then": { "$ref": "#/$defs/selectInteraction" }
            },
            {
              "if": {
                "properties": {
                  "type": { "const": "CLOZE" }
                }
              },
              "then": { "$ref": "#/$defs/clozeInteraction" }
            },
            {
              "if": {
                "properties": {
                  "type": { "const": "EXECUTABLE" }
                }
              },
              "then": { "$ref": "#/$defs/executableInteraction" }
            }
          ]
        }
      }
    },

    "headerBlock": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "header" },
        "content": { "type": "string" },
        "clientId": { "type": "string", "format": "uuid" }
      }
    },

    "paragraphBlock": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "paragraph" },
        "content": { "type": "string" },
        "clientId": { "type": "string", "format": "uuid" }
      }
    },

    "codeBlock": {
      "type": "object",
      "required": ["type", "language", "content"],
      "properties": {
        "type": { "const": "code" },
        "language": { "type": "string" },
        "content": { "type": "string" },
        "output": { "type": ["string", "null"] },
        "clientId": { "type": "string", "format": "uuid" }
      }
    },

    "instructionsBlock": {
      "type": "object",
      "required": ["type", "instructions"],
      "properties": {
        "type": { "const": "instructions" },
        "instructions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "clientId": { "type": "string", "format": "uuid" }
      }
    },

    "mediaBlock": {
      "type": "object",
      "required": ["type", "src"],
      "properties": {
        "type": { "const": "media" },
        "src": { "type": "string" },
        "alt": { "type": ["string", "null"] },
        "clientId": { "type": "string", "format": "uuid" }
      }
    },

    "selectInteraction": {
      "type": "object",
      "required": ["type", "items", "correctValue"],
      "properties": {

        "type": {
          "const": "SELECT"
        },

        "clientId": {
          "type": "string",
          "format": "uuid"
        },

        "items": {
          "type": "array",
          "items": { "type": "string" }
        },

        "correctValue": {
          "type": "string"
        }
      }
    },

    "clozeInteraction": {
      "type": "object",
      "required": ["type", "file", "blanks", "options"],
      "properties": {

        "type": {
          "const": "CLOZE"
        },

        "clientId": {
          "type": "string",
          "format": "uuid"
        },

        "file": {
          "$ref": "#/$defs/file"
        },

        "blanks": {
          "type": "array",
          "items": { "$ref": "#/$defs/blank" }
        },

        "options": {
          "type": "array",
          "items": { "type": "string" }
        },

        "output": {
          "type": ["string", "null"]
        }
      }
    },

    "executableInteraction": {
      "type": "object",
      "required": ["type", "files", "tests"],
      "properties": {

        "type": {
          "const": "EXECUTABLE"
        },

        "clientId": {
          "type": "string",
          "format": "uuid"
        },

        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/executableFile" }
        },

        "tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/executableTest" }
        },

        "showOutput": {
          "type": "boolean"
        }
      }
    },

    "executableFile": {
      "type": "object",
      "required": ["name", "language", "content"],
      "properties": {
        "name": { "type": "string" },
        "language": { "type": "string" },
        "content": { "type": "string" }
      }
    },

    "executableTest": {
      "type": "object",
      "required": ["type", "expected"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "OUTPUT_EQUALS",
            "OUTPUT_CONTAINS",
            "FILE_CONTAINS"
          ]
        },
        "expected": {
          "type": "string"
        }
      }
    },

    "blank": {
      "type": "object",
      "required": ["index", "correctOptions"],
      "properties": {

        "index": {
          "type": "integer"
        },

        "correctOptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "file": {
      "type": "object",
      "required": ["language", "content"],
      "properties": {

        "language": {
          "type": "string"
        },

        "content": {
          "type": "string"
        }
      }
    }

  }
}